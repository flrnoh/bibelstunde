# JWT signing secret — generate with: openssl rand -base64 64
JWT_SECRET=

# Upstash Redis (via Vercel Marketplace integration "Upstash for Redis")
# When you add the integration to the project, these are injected automatically.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Stripe — get from https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Brevo Transactional — get from https://app.brevo.com (SMTP & API → API Keys)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# Used for Stripe success/cancel URLs and the login URL in mails.
# Leave empty in dev (auto-derived from request); set to https://bibelstunde.app once domain is live.
APP_BASE_URL=
