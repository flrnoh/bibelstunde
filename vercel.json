{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/app", "destination": "/app/index.html" }
  ],
  "redirects": [
    { "source": "/", "destination": "/app", "permanent": false },
    { "source": "/login", "destination": "/app", "permanent": false }
  ]
}
